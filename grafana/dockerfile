# UI for all observability data. Auto-provisions datasources and dashboards from files.
# Configured via grafana.ini (Google OAuth, Security, etc.)
# To add dashboards: build in UI, export JSON, drop in grafana/dashboards/, redeploy.

ARG VERSION=12.4.0

FROM grafana/grafana-oss:${VERSION}

# Railway volumes mount as root-owned directories
USER root

COPY . /etc/grafana
