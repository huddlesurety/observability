          "datasource": {
            "type": "tempo",
            "uid": "grafana_tempo"
          },
          "refId": "A",
          "queryType": "traceql",
          "tableType": "traces",
          "limit": 20,
          "query": "{ resource.service.name = \"RAG\" && resource.deployment.environment = \"$environment\" && name = \"RunWorkflow:$workflow\" }",
          "filters": []
        }
      ]
    },
