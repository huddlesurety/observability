        "h": 9,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "repeat": "workflow",
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "axisLabel": "",
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "grafana_tempo"
          },
          "refId": "A",
          "queryType": "traceql",
          "query": "{ resource.service.name = \"RAG\" && resource.deployment.environment = \"$environment\" && name =~ \"RunActivity:.*\" && span.workflow.type = \"$workflow\" } | avg_over_time(duration) by (name)"
        }
      ],
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "mean"
            ],
            "mode": "seriesToRows"
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "Mean",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Recent $workflow runs \u2014 click a trace to open its waterfall",
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "description": "Per-execution trace list for the selected workflow, slowest first. Click a trace to expand the waterfall: bar length = activity duration, bar offset = start time, so parallel activities show as overlapping bars. This is the honest per-run view (the aggregate bar panels can't show parallelism).",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 20
      },
