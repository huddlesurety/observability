        }
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "grafana_tempo"
          },
          "query": "{ resource.service.name = \"RAG\" && resource.deployment.environment = \"$environment\" && name =~ \"RunWorkflow:.*\" } | rate() by (name)",
          "queryType": "traceql",
          "refId": "A"
