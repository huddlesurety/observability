  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Pipeline \u2014 workflow level (spanmetrics)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Workflow p95 duration",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_duration_seconds_bucket{service_name=\"RAG\", deployment_environment=\"$environment\", span_name=~\"RunWorkflow:.+\"}[$__rate_interval])))",
          "legendFormat": "{{span_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "grafana_prometheus"
          },
          "exemplar": true
        }
      ],
      "description": "p95 end-to-end per workflow, from trace spans. Dots are exemplars \u2014 click to open the exact trace in Tempo."
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Workflow throughput (per minute)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=\"RAG\", deployment_environment=\"$environment\", span_name=~\"RunWorkflow:.+\"}[$__rate_interval])) * 60",
          "legendFormat": "{{span_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "grafana_prometheus"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Workflow error rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 12,
            "showPoints": "never"
          },
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=\"RAG\", deployment_environment=\"$environment\", span_name=~\"RunWorkflow:.+\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=\"RAG\", deployment_environment=\"$environment\", span_name=~\"RunWorkflow:.+\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "grafana_prometheus"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Activity retries / failures",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
