    {
      "id": 15,
      "type": "stat",
      "title": "Grounding miss ratio",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 51
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(rag_grounding_misses_total{service_name=\"RAG\", deployment_environment=\"$environment\"}[$__range])) / sum(increase(rag_grounding_checks_total{service_name=\"RAG\", deployment_environment=\"$environment\"}[$__range]))",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "grafana_prometheus"
          }
        }
      ],
      "description": "Answers that could not be tied back to a source quote (no evidence image). Silent quality failure."
    },
