        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (activity_type) (rate(temporal_activity_execution_failed_total{service_name=\"RAG\", deployment_environment=\"$environment\", namespace=\"$environment\"}[$__rate_interval])) * 60",
