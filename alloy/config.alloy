logging {
  level  = "info"
  format = "json"
}

// 1. Receives OTLP data
otelcol.receiver.otlp "default" {
  http {
    endpoint = "0.0.0.0:4318"
  }
  output {
    metrics = [otelcol.processor.transform.add_resource_attributes.input]
    logs    = [otelcol.processor.batch.default.input]
    traces  = [otelcol.processor.batch.default.input]
  }
}

// 2. Receives Faro RUM data
faro.receiver "default" {
  server {
    listen_address = "0.0.0.0"
    cors_allowed_origins = ["*"]
  }
  
  output {
    logs   = [loki.process.faro_logs.receiver]
    traces = [otelcol.processor.batch.default.input]
  }
}

// 3. Process Faro Logs
loki.process "faro_logs" {
  forward_to = [loki.write.local.receiver]

  stage.logfmt {
    mapping = {
      "service_name" = "app_name",
      "session_id" = "session_id",
      "browser" = "browser_name",
      "deployment_environment" = "app_environment",
    }
  }

  stage.labels {
    values = {
      "service_name" = "service_name",
      "session_id" = "session_id",
      "browser" = "browser",
      "deployment_environment" = "deployment_environment",
    }
  }
}

// 4. Promote resource attributes to metric labels
otelcol.processor.transform "add_resource_attributes" {
  error_mode = "ignore"
  metric_statements {
    context = "datapoint"
    statements = [
      "set(attributes[\"service_name\"], resource.attributes[\"service.name\"])",
      "set(attributes[\"deployment_environment\"], resource.attributes[\"deployment.environment\"])",
    ]
  }
  output {
    metrics = [otelcol.processor.batch.default.input]
  }
}

otelcol.processor.batch "default" {
  output {
    metrics = [otelcol.exporter.prometheus.local.input]
    logs    = [otelcol.exporter.loki.local.input]
    traces  = [
      otelcol.exporter.otlphttp.local.input,
      otelcol.connector.spanmetrics.default.input,
      otelcol.connector.servicegraph.default.input,
    ]
  }
}

// Derive RED metrics (rate/errors/duration) from spans so stage/route latency
// dashboards need no hand-written duration metrics. Exemplars link each
// histogram bucket to a real trace ID in Tempo.
otelcol.connector.spanmetrics "default" {
  histogram {
    unit = "s"
    explicit {
      // RAG stages span ms (DB lookups) to minutes (OCR parse, LLM calls)
      buckets = ["100ms", "250ms", "500ms", "1s", "2s", "5s", "10s", "30s", "1m", "2m", "5m", "10m"]
    }
  }

  // service.name, span.name, span.kind and status.code are always included.
  // rag.workflow / rag.stage are set by the RAG worker's stage spans (Phase 2).
  dimension {
    name = "rag.workflow"
  }
  dimension {
    name = "rag.stage"
  }

  exemplars {
    enabled = true
  }

  namespace              = "traces_spanmetrics"
  metrics_flush_interval = "15s"

  // Dedicated downstream path (transform/batch "connector_metrics"): routing
  // back into batch.default would create a cycle (batch feeds this connector).
  output {
    metrics = [otelcol.processor.transform.connector_metrics.input]
  }
}

// Same resource-attribute promotion as add_resource_attributes, on a separate
// instance so connector-generated metrics don't loop back into batch.default.
otelcol.processor.transform "connector_metrics" {
  error_mode = "ignore"
  metric_statements {
    context = "datapoint"
    statements = [
      "set(attributes[\"service_name\"], resource.attributes[\"service.name\"])",
      "set(attributes[\"deployment_environment\"], resource.attributes[\"deployment.environment\"])",
    ]
  }
  output {
    metrics = [otelcol.processor.batch.connector_metrics.input]
  }
}

otelcol.processor.batch "connector_metrics" {
  output {
    metrics = [otelcol.exporter.prometheus.local.input]
  }
}

// Service dependency graph (App -> API -> RAG -> OpenRouter/...) for the
// Grafana service map. Emits traces_service_graph_request_* metrics.
otelcol.connector.servicegraph "default" {
  latency_histogram_buckets = ["100ms", "250ms", "1s", "5s", "10s", "30s", "1m", "5m", "10m"]
  dimensions                = ["deployment.environment"]

  output {
    metrics = [otelcol.processor.batch.connector_metrics.input]
  }
}

// Convert OTLP metrics to Prometheus format
otelcol.exporter.prometheus "local" {
  forward_to = [prometheus.remote_write.local.receiver]
}

// Convert OTLP logs to Loki format
otelcol.exporter.loki "local" {
  forward_to = [loki.write.local.receiver]
}

// Exports metrics to Prometheus
prometheus.remote_write "local" {
  endpoint {
    url            = sys.env("PROMETHEUS_ENDPOINT")
    send_exemplars = true
  }
}

// Exports logs to Loki
loki.write "local" {
  endpoint {
    url = sys.env("LOKI_ENDPOINT")
  }
}

// Exports traces to Tempo via OTLP HTTP
otelcol.exporter.otlphttp "local" {
  client {
    endpoint = sys.env("TEMPO_ENDPOINT")
  }
}

// Blackbox exporter for active health checking
prometheus.exporter.blackbox "default" {
  config = `
modules:
  http_2xx:
    prober: http
    timeout: 5s
    http:
      valid_http_versions: ["HTTP/1.1", "HTTP/2.0"]
      method: GET
      tls_config:
        insecure_skip_verify: true
`
  target {
    name    = "App-staging"
    address = "https://app.staging.huddlesurety.co/api/health"
    module  = "http_2xx"
  }

  target {
    name    = "API-staging"
    address = "https://api.staging.huddlesurety.co/"
    module  = "http_2xx"
  }

  target {
    name    = "App-production"
    address = "https://app.huddlesurety.co/api/health"
    module  = "http_2xx"
  }

  target {
    name    = "API-production"
    address = "https://api.huddlesurety.co/"
    module  = "http_2xx"
  }
}

discovery.relabel "blackbox" {
  targets = prometheus.exporter.blackbox.default.targets

  rule {
    source_labels = ["__param_target"]
    target_label  = "target_address"
  }

  rule {
    source_labels = ["job"]
    regex         = "integrations/blackbox/([^-]+)-.*"
    target_label  = "service_name"
  }

  rule {
    source_labels = ["job"]
    regex         = "integrations/blackbox/[^-]+-(.*)"
    target_label  = "deployment_environment"
  }
}

// Scrape the blackbox exporter targets
prometheus.scrape "blackbox" {
  targets         = discovery.relabel.blackbox.output
  forward_to      = [prometheus.remote_write.local.receiver]
  scrape_interval = "1m"
}
